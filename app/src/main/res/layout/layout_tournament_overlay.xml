<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardQuizWindow"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clickable="true"
    android:focusable="true">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/glass_border_red"
        android:alpha="0.1" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnCloseTournament"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="TOURNAMENT ARENA"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:letterSpacing="0.2" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/ivFloatingTortoise"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/wise_tortoise_logo"
            android:layout_marginBottom="30dp" />

        <TextView
            android:id="@+id/tvLiveQuestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENT JACKPOT"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTournamentJackpot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KES 0.00"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:layout_marginTop="5dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnJoinTournamentFinal"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="JOIN TOURNAMENT (10/-)"
            android:backgroundTint="#FFD700"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnMinimize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </LinearLayout>

</RelativeLayout>
