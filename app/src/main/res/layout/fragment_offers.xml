<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_black"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/glass_white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvPremiumStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS: RESTRICTED"
                    android:textColor="@color/text_gray"
                    android:textStyle="bold"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spend KES 50 in Market to unlock full rewards"
                    android:textColor="@color/primary_red"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REFERRAL PROGRAM"
            android:textColor="@color/primary_red"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tvMyReferralCode"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="@drawable/glass_border_red"
                android:gravity="center"
                android:hint="CODE"
                android:textColor="@color/white"
                android:textColorHint="@color/text_gray"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnShareCode"
                android:layout_width="wrap_content"
                android:layout_height="55dp"
                android:layout_marginStart="10dp"
                android:text="SHARE"
                android:backgroundTint="@color/primary_red"
                app:cornerRadius="8dp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etInputReferral"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="Enter Friend's Code"
            android:textColor="@color/white"
            android:textColorHint="@color/text_gray"
            android:background="@drawable/glass_border_red"
            android:padding="12dp"
            android:inputType="textCapCharacters"/>

        <Button
            android:id="@+id/btnClaimReferral"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="CLAIM KES 0.50 BONUS"
            android:backgroundTint="@color/cyber_black"
            android:textColor="@color/primary_red"
            app:strokeColor="@color/primary_red"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnDailyCheckIn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:text="DAILY CHECK-IN (0.10)"
            android:backgroundTint="@color/secondary_red"
            android:textStyle="bold"
            app:cornerRadius="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WEEKLY AD KING LEADERBOARD"
            android:textColor="@color/primary_red"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:layout_marginTop="10dp"
            android:background="@color/glass_white"
            android:padding="8dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
