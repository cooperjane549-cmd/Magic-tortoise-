<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/timerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:60"
            android:textColor="#FFD700"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIME REMAINING"
            android:textColor="#666666"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/gameStage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/scoreContainer"
        android:layout_below="@id/timerContainer"
        android:layout_marginVertical="30dp">
        
        <TextView
            android:id="@+id/tvWaitingMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Waiting for Opponent..."
            android:textColor="#FFF" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/scoreContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tvMyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOU: 0"
            android:textColor="#4CAF50"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/pbMyProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginBottom="12dp"
            android:progress="0"
            android:progressDrawable="@android:drawable/progress_horizontal" />

        <TextView
            android:id="@+id/tvOpponentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPPONENT: 0"
            android:textColor="#F44336"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/pbOpponentProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:progress="0" />

    </LinearLayout>

</RelativeLayout>
