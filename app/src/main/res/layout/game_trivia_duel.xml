<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/tvTriviaQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="What is the capital of Kenya?"
        android:textColor="#FFF"
        android:textSize="20sp"
        android:textAlignment="center"
        android:layout_marginBottom="20dp" />

    <Button android:id="@+id/btnOpt1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Option A" android:layout_marginBottom="5dp"/>
    <Button android:id="@+id/btnOpt2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Option B" android:layout_marginBottom="5dp"/>
    <Button android:id="@+id/btnOpt3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Option C" android:layout_marginBottom="5dp"/>
    <Button android:id="@+id/btnOpt4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Option D" />
</LinearLayout>
