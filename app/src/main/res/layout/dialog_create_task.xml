<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. INSTRUCTIONS"
        android:textColor="#FF0033"
        android:textStyle="bold"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pay KES 450 to Till: 3043489 (Magic Tortoise). Your task will go live for 1,200 users after verification."
        android:textColor="#BBBBBB"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. SOCIAL MEDIA LINK"
        android:textColor="#FF0033"
        android:textStyle="bold"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_social_link"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="e.g. tiktok.com/@username"
        android:textColor="#FFFFFF"
        android:textColorHint="#555555"
        android:backgroundTint="#FF0033"
        android:inputType="textUri"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3. PAYMENT VERIFICATION"
        android:textColor="#FF0033"
        android:textStyle="bold"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_payment_ref"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter M-Pesa Transaction Code"
        android:textColor="#FFFFFF"
        android:textColorHint="#555555"
        android:backgroundTint="#FF0033"
        android:textAllCaps="true" />

</LinearLayout>
