<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MAGIC TORTOISE"
            android:textColor="@color/primary_red"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="25dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/glass_white">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="25dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Shells"
                    android:textColor="@color/text_gray" />
                <TextView
                    android:id="@+id/tvBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="@color/white"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:layout_centerInParent="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SHELLS"
                    android:textColor="@color/primary_red"
                    android:layout_below="@id/tvBalance"
                    android:layout_centerHorizontal="true"
                    android:textSize="12sp"
                    android:letterSpacing="0.2"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="30dp"
            android:weightSum="4">
            
            <include layout="@layout/item_action_icon" android:id="@+id/actionAds" />
            <include layout="@layout/item_action_icon" android:id="@+id/actionMarket" />
            <include layout="@layout/item_action_icon" android:id="@+id/actionLeaderboard" />
            <include layout="@layout/item_action_icon" android:id="@+id/actionMore" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAdProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily Progress: 0/35"
            android:textColor="@color/primary_red"
            android:layout_marginTop="35dp"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/adProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="8dp"
            android:max="35"
            android:progressDrawable="@drawable/custom_progress_bar" />

        <Button
            android:id="@+id/btnWatchAd"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="20dp"
            android:text="COLLECT REWARD"
            android:backgroundTint="@color/primary_red"
            android:textStyle="bold"
            app:cornerRadius="18dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
