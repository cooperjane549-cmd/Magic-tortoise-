<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. SET PAYOUT NUMBER"
            android:textColor="#E91E63"
            android:textStyle="bold"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/etUserNumber"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:hint="07XXXXXXXX"
                android:inputType="phone"
                android:textColor="@color/white"
                android:background="@drawable/glass_border_red"
                android:padding="12dp"
                android:textColorHint="#555555" />

            <Button
                android:id="@+id/btnSaveNumber"
                android:layout_width="wrap_content"
                android:layout_height="55dp"
                android:layout_marginStart="10dp"
                android:text="SAVE"
                android:backgroundTint="#2E7D32"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#222222" android:layout_marginVertical="25dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. BUY AIRTIME (2% DISCOUNT)"
            android:textColor="#00E676"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etBuyAmount"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Amount (5 - 500)"
            android:inputType="number"
            android:textColor="@color/white"
            android:background="@drawable/glass_border_red"
            android:padding="12dp"
            android:textColorHint="#555555" />

        <Button
            android:id="@+id/btnBuyWithMpesa"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="15dp"
            android:text="BUY NOW (STK PUSH)"
            android:backgroundTint="#E91E63"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#222222" android:layout_marginVertical="25dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. REDEEM EARNED SHELLS"
            android:textColor="#FFC107"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCurrentShells"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available: 0.00 Shells"
            android:textColor="@color/white"
            android:layout_marginTop="5dp" />

        <EditText
            android:id="@+id/etRedeemAmount"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Redeem Amount (Min 3)"
            android:inputType="number"
            android:textColor="@color/white"
            android:background="@drawable/glass_border_red"
            android:padding="12dp"
            android:textColorHint="#555555" />

        <Button
            android:id="@+id/btnRedeemAirtime"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="15dp"
            android:text="REDEEM TO AIRTIME"
            android:backgroundTint="#FFC107"
            android:textColor="#000000"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
