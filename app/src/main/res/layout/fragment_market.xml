<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            app:cardBackgroundColor="#1A1A1A"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GRAND TOURNAMENT"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvTournamentJackpot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WIN KES 0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginTop="5dp"/>
                <Button
                    android:id="@+id/btnEnterTournament"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="OPEN TOURNAMENT GATE"
                    android:backgroundTint="#FFD700"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginTop="15dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYNC ARENA (2-10 PLAYERS)"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#121212">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">
                <Button
                    android:id="@+id/btnSyncNow"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="SELECT SYNC TIER"
                    android:backgroundTint="#FF0000"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P2P BATTLE LOBBY"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnCreateBattle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="+ CREATE"
                android:layout_alignParentEnd="true"
                android:backgroundTint="#333"
                android:textColor="#FFD700" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/p2pContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp" />

    </LinearLayout>
</ScrollView>
