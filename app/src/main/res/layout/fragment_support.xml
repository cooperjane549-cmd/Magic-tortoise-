<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090909"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROFILE &amp; SUPPORT"
            android:textColor="#FF0033"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivUserProfilePic"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:padding="2dp"
            app:strokeColor="#FF0033"
            app:strokeWidth="2dp"
            app:shapeAppearanceOverlay="@style/CircleImage"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop"/>

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Full Name"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:backgroundTint="#FF0033"
            android:layout_marginTop="32dp"
            android:inputType="textPersonName"/>

        <EditText
            android:id="@+id/etPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="M-Pesa Number (07...)"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:backgroundTint="#FF0033"
            android:layout_marginTop="16dp"
            android:inputType="phone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SECURE PROFILE (2 YEARS)"
            android:backgroundTint="#FF0033"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"
            app:cornerRadius="12dp"/>

        <TextView
            android:id="@+id/tvRestrictionNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Note: Once saved, you cannot change this until 2028."
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NEED HELP?"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhatsApp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="WHATSAPP"
                android:textColor="#FFFFFF"
                app:strokeColor="#25D366"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTelegram"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="TELEGRAM"
                android:textColor="#FFFFFF"
                app:strokeColor="#0088CC"/>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
